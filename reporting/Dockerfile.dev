FROM python:3.13-slim

WORKDIR /app
COPY pyproject.toml requirements.lock ./
RUN pip install -r requirements.lock --no-cache-dir && \
    pip install -e . --no-deps --no-cache-dir

COPY . .

EXPOSE 8081
# Reporting is a batch job service — no web server needed yet.
# Container stays alive for running jobs interactively via docker exec.
CMD ["python", "-m", "http.server", "8081"]
